{
  "name": "precompile-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run verify:recipes && tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run consumer:test && npm run test:e2e",
    "smoke:production": "node scripts/smoke-production.mjs",
    "verify:recipes": "node scripts/verify-recipes.mjs",
    "consumer:build": "forge build",
    "consumer:test": "forge test",
    "consumer:deploy": "forge create --broadcast --rpc-url https://rpc.ritualfoundation.org --private-key $RITUAL_PRIVATE_KEY contracts/HttpPrecompileConsumer.sol:HttpPrecompileConsumer"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "viem": "^2.54.1",
    "vite": "^6.0.3"
  },
  "overrides": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.10"
  }
}
